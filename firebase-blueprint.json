{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Audit": {
      "title": "Audit",
      "description": "Fairness audit result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "datasetName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "fairnessScore": { "type": "number" },
        "metrics": { "type": "object" },
        "selectionRates": { "type": "object" },
        "aiInsights": { "type": "string" },
        "grade": { "type": "string" },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "outcomeColumn": { "type": "string" },
        "protectedColumn": { "type": "string" }
      },
      "required": ["userId", "datasetName", "timestamp", "fairnessScore"]
    },
    "ModelAudit": {
      "title": "ModelAudit",
      "description": "Model performance audit result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "datasetName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "metrics": { "type": "object" },
        "protectedColumn": { "type": "string" },
        "actualColumn": { "type": "string" },
        "predictedColumn": { "type": "string" }
      },
      "required": ["userId", "datasetName", "timestamp", "metrics"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/audits/{auditId}": {
      "schema": "Audit",
      "description": "Audit result document"
    },
    "/model_audits/{auditId}": {
      "schema": "ModelAudit",
      "description": "Model performance audit document"
    }
  }
}
